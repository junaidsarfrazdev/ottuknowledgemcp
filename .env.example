# Copy to .env (gitignored). setup.sh / setup.ps1 can also create this for you.

# Absolute path to where your Ottu repos are cloned.
# Example: /Users/you/ottu-workspace  or  C:\Users\you\ottu-workspace
OTTU_WORKSPACE=

# Optional: absolute path to a JSON file overriding the default repo list.
# See ottu_config.example.json.
# OTTU_CONFIG=

OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
CHROMA_DB_PATH=./chroma_db
